# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Workforce Pro
APP_VERSION=1.0.0
DEBUG=False

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/workforce_pro

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (JSON array of allowed origins) ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Redis (optional — for caching/sessions) ───────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Email / SMTP (optional — for notifications) ───────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=noreply@yourcompany.com

# ── File Storage / S3 (optional — for uploads) ────────────────────────────────
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=workforce-pro-uploads
# AWS_REGION=ap-south-1
