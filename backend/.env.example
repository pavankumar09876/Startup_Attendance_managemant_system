# Application
APP_NAME=Workforce Pro
DEBUG=False

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/workforce_pro

# JWT
SECRET_KEY=change-this-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated)
ALLOWED_ORIGINS=["http://localhost:3000"]
