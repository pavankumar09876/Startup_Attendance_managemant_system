****For Docker Compose***

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=wfp_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=workforce_pro

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wfp_user:your_strong_password_here@localhost:5432/workforce_pro
SECRET_KEY=change-this-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SendGrid or SMTP) ──────────────────────────────────────────────────
# SENDGRID_API_KEY=SG.xxxx
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=noreply@yourcompany.com

# ── Storage (S3-compatible) ───────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=workforce-pro-uploads
# AWS_REGION=ap-south-1

# ── App settings ──────────────────────────────────────────────────────────────
APP_NAME=Workforce Pro
APP_VERSION=1.0.0
